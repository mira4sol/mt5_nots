{
  "id": "mt5-whatsapp-commands",
  "name": "MT5 WhatsApp Commands",
  "description": "MT5 slash commands for WhatsApp groups via registerCommand + webhook fallback",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiBaseUrl": {
        "type": "string",
        "description": "mt5_trigger HTTP base URL"
      },
      "webhookUrl": {
        "type": "string",
        "description": "mt5_trigger inbound webhook URL"
      },
      "groupJids": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Allowed WhatsApp group JIDs"
      },
      "accountsByGroup": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Map group JID to mt5_trigger account name"
      },
      "admins": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "WhatsApp admins (synced from config/settings.yaml)"
      },
      "apiToken": {
        "type": "string",
        "description": "Optional X-API-Token for mt5_trigger HTTP"
      }
    }
  }
}
