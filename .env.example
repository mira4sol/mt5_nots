# Copy to .env and fill in values (never commit .env)

MT5_LOGIN=501086912
MT5_PASSWORD=your_investor_password
MT5_SERVER=ValetaxGlobal-Live3

# WhatsApp E.164 (+15551234567) or group JID (120363...@g.us)
WHATSAPP_TARGET=

# --- MT5 connection (Linux VPS example) ---
#
# MT5_BACKEND must be one of: auto | native | bridge | mock
#   NOT "mt5linux" — that is the bridge CLIENT (see MT5_BRIDGE_CLIENT below)
#
MT5_BACKEND=bridge
MT5_BRIDGE_CLIENT=mt5linux
MT5_BRIDGE_HOST=127.0.0.1
MT5_BRIDGE_PORT=18812
MT5_TERMINAL_PATH=C:\Program Files\Valetax Global MT5 Terminal\terminal64.exe

# Mac example instead:
# MT5_BACKEND=bridge
# MT5_BRIDGE_CLIENT=mac-bridge
# MT5_BRIDGE_HOST=127.0.0.1
# MT5_BRIDGE_PORT=18813
