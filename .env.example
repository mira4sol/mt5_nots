# Copy to .env and fill in values (never commit .env)

MT5_LOGIN=501086912
MT5_PASSWORD=your_investor_password
MT5_SERVER=ValetaxGlobal-Live3

# WhatsApp E.164 (+15551234567) or group JID (120363...@g.us)
WHATSAPP_TARGET=

# Backend: auto | native | bridge | mock
MT5_BACKEND=auto

# Bridge client when mt5_backend=bridge:
#   mt5linux    — Linux Wine RPyC server (python -m mt5linux ...)  ← most VPS setups
#   mac-bridge  — mt5-mac-bridge / siliconmetatrader5 (Mac MT5.app)
#   auto        — picks mt5linux if installed, else mac-bridge
MT5_BRIDGE_CLIENT=auto
MT5_BRIDGE_HOST=localhost
MT5_BRIDGE_PORT=18813

# Wine path to terminal64.exe (required for mt5linux on Linux)
# MT5_TERMINAL_PATH=C:\Program Files\Valetax Global MT5 Terminal\terminal64.exe